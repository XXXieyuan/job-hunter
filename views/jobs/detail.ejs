<section class="detail-layout">
  <div class="detail-main card">
    <a class="text-link" href="/jobs?lang=<%= lang || 'zh' %>">← <%= lang === 'en' ? 'Back to jobs' : '返回职位列表' %></a>
    <div class="detail-header">
      <div>
        <span class="badge badge-source badge-source--<%= (job.source || 'seek').toLowerCase() %>"><%= job.source_label || job.source %></span>
        <h1><%= job.title %></h1>
        <p class="job-card__meta"><%= job.company || '—' %> · <%= job.location || 'Australia' %></p>
      </div>
      <div class="status-pill"><%= lang === 'en' ? 'Status' : '状态' %>: <%= status || 'unread' %></div>
    </div>

    <div class="detail-grid">
      <article>
        <h2><%= lang === 'en' ? 'Job description' : '职位描述' %></h2>
        <p class="long-copy"><%= job.job_description %></p>
      </article>
      <aside class="detail-sidebar">
        <div class="card inset-card">
          <h3><%= lang === 'en' ? 'Match summary' : '匹配摘要' %></h3>
          <% const scoreValue = Number(match && match.total_score || 0); %>
          <div class="score-ring score-ring--<%= scoreValue >= 70 ? 'high' : scoreValue >= 40 ? 'mid' : 'low' %>">
            <strong><%= Math.round(scoreValue) %></strong>
            <span><%= lang === 'en' ? 'Score' : '总分' %></span>
          </div>
          <ul class="metric-list">
            <li><span>Skill</span><strong><%= Math.round(match && match.skill_score || 0) %></strong></li>
            <li><span>Semantic</span><strong><%= Math.round(match && match.semantic_score || 0) %></strong></li>
            <li><span>Keyword</span><strong><%= Math.round(match && match.keyword_score || 0) %></strong></li>
          </ul>
          <div class="gap-block">
            <h4><%= lang === 'en' ? 'Gap analysis' : '差距分析' %></h4>
            <p><strong><%= lang === 'en' ? 'Missing' : '缺失' %>:</strong> <%= (match && match.gap_analysis && match.gap_analysis.missing || []).join(', ') || '—' %></p>
            <p><strong><%= lang === 'en' ? 'Strong' : '优势' %>:</strong> <%= (match && match.gap_analysis && match.gap_analysis.strong || []).join(', ') || '—' %></p>
          </div>
        </div>

        <div class="card inset-card">
          <h3><%= lang === 'en' ? 'Cover letters' : 'Cover Letter' %></h3>
          <form class="cover-letter-form" data-cover-letter-form>
            <input type="hidden" name="job_id" value="<%= job.id %>" />
            <input type="hidden" name="resume_id" value="<%= primaryResume ? primaryResume.id : '' %>" />
            <label class="form-field">
              <span><%= lang === 'en' ? 'Language' : '语言' %></span>
              <select name="language">
                <option value="en">English</option>
                <option value="zh">中文</option>
              </select>
            </label>
            <button class="btn btn-primary" type="submit"><%= lang === 'en' ? 'Generate cover letter' : '生成 Cover Letter' %></button>
          </form>
          <textarea class="cover-letter-output" data-cover-letter-output><%= (coverLetters[0] && coverLetters[0].content) || '' %></textarea>
          <div class="button-row">
            <button class="btn btn-secondary" type="button" data-copy-cover-letter><%= lang === 'en' ? 'Copy' : '复制' %></button>
            <button class="btn btn-secondary" type="button" data-download-cover-letter><%= lang === 'en' ? 'Download' : '下载' %></button>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
