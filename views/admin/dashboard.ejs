<section class="admin-layout">
  <div class="stats-grid">
    <article class="card stat-card"><span><%= lang === 'en' ? 'Jobs' : '职位总数' %></span><strong><%= stats.jobs_total %></strong></article>
    <article class="card stat-card"><span><%= lang === 'en' ? 'Resumes' : '简历总数' %></span><strong><%= stats.resumes_total %></strong></article>
    <article class="card stat-card"><span><%= lang === 'en' ? 'Matches' : '已分析' %></span><strong><%= stats.matched_total %></strong></article>
    <article class="card stat-card"><span><%= lang === 'en' ? 'Cover letters' : 'CL 数量' %></span><strong><%= stats.cl_total %></strong></article>
  </div>

  <div class="admin-grid">
    <div class="card">
      <div class="section-header">
        <h2><%= lang === 'en' ? 'Source distribution' : '来源分布' %></h2>
      </div>
      <% Object.entries(stats.by_source || {}).forEach(function(entry) { %>
        <div class="source-bar">
          <div class="source-bar__label"><span><%= entry[0] %></span><span><%= entry[1] %></span></div>
          <div class="progress"><span class="progress__fill progress__fill--<%= entry[0] %>" style="width: <%= totalJobs ? (entry[1] / totalJobs) * 100 : 0 %>%"></span></div>
        </div>
      <% }) %>
    </div>

    <div class="card">
      <div class="section-header">
        <h2><%= lang === 'en' ? 'OpenAI config' : 'OpenAI 配置' %></h2>
      </div>
      <form class="admin-config-form" data-admin-config-form>
        <label class="form-field">
          <span>Base URL</span>
          <input type="url" name="openai_base_url" value="<%= publicConfig.openai_base_url || '' %>" />
        </label>
        <label class="form-field">
          <span>API Key</span>
          <input type="password" name="openai_api_key" value="" placeholder="sk-..." />
        </label>
        <button class="btn btn-primary" type="submit"><%= lang === 'en' ? 'Save config' : '保存配置' %></button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="section-header">
      <h2><%= lang === 'en' ? 'System logs' : '系统日志' %></h2>
      <select data-log-filter>
        <option value=""><%= lang === 'en' ? 'All levels' : '全部等级' %></option>
        <option value="info">Info</option>
        <option value="warn">Warn</option>
        <option value="error">Error</option>
      </select>
    </div>
    <div class="log-list" data-log-list>
      <% (logs || []).forEach(function(entry) { %>
        <article class="log-item log-item--<%= entry.level %>">
          <strong><%= entry.action %></strong>
          <span><%= entry.detail %></span>
          <time><%= entry.created_at %></time>
        </article>
      <% }) %>
    </div>
  </div>
</section>
