<% layout('layout') -%>

<section class="page-section">
  <div class="section-header">
    <h1><%= t('resumes.upload.title', '上传简历') %></h1>
    <p class="section-subtitle">
      <%= t(
        'resumes.upload.subtitle',
        '上传 .docx 简历文件，系统会自动提取关键信息并用于职位匹配和 Cover Letter 生成。'
      ) %>
    </p>
  </div>

  <div class="glass-card">
    <form method="post" action="/resumes/upload" enctype="multipart/form-data" style="display:flex; flex-direction: column; gap: 12px;">
      <div class="filter-group">
        <label for="resume">
          <%= t('resumes.upload.fileLabel', '选择简历文件 (.docx)：') %>
        </label>
        <input type="file" id="resume" name="resume" accept=".docx,.txt" required />
      </div>
      <div>
        <button type="submit" class="btn btn-primary">
          <%= t('resumes.upload.submit', '上传并解析') %>
        </button>
        <a href="/resumes" class="btn btn-ghost" style="margin-left:8px;">
          <%= t('resumes.upload.backToList', '返回列表') %>
        </a>
      </div>
      <p class="muted small">
        <%= t(
          'resumes.upload.hint',
          '文件大小限制 5MB。上传后可在「我的简历」页面设置哪一份为主简历。'
        ) %>
      </p>
    </form>
  </div>
</section>
