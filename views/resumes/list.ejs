<section class="resumes-layout">
  <div class="card upload-card">
    <p class="eyebrow"><%= lang === 'en' ? 'Resume hub' : '简历中心' %></p>
    <h1><%= lang === 'en' ? 'Upload and manage your resumes' : '上传并管理你的简历' %></h1>
    <form class="upload-form" data-resume-form enctype="multipart/form-data" method="post" action="/api/resumes/upload">
      <label class="upload-dropzone" data-upload-zone>
        <input type="file" name="file" accept=".docx,.pdf" />
        <span><%= lang === 'en' ? 'Drop a .docx or .pdf here, or click to browse.' : '拖放 .docx / .pdf 文件到这里，或点击选择。' %></span>
      </label>
      <button class="btn btn-primary" type="submit"><%= lang === 'en' ? 'Upload resume' : '上传简历' %></button>
    </form>
  </div>

  <div class="resume-grid">
    <% if ((resumes || []).length) { %>
      <% resumes.forEach(function(resume) { %>
        <article class="card resume-card">
          <div class="resume-card__header">
            <h2><%= resume.name %></h2>
            <% if (resume.is_primary) { %><span class="badge badge-primary"><%= lang === 'en' ? 'Primary' : '主简历' %></span><% } %>
          </div>
          <p class="text-muted"><%= resume.file_name %></p>
          <p><%= lang === 'en' ? 'Skills' : '技能' %>: <%= (resume.parsed_data.skills || []).slice(0, 6).join(', ') || '—' %></p>
          <p><%= lang === 'en' ? 'Experience' : '经验' %>: <%= (resume.parsed_data.experience || []).slice(0, 2).join(' · ') || '—' %></p>
          <div class="button-row">
            <button class="btn btn-secondary" type="button" data-set-primary data-id="<%= resume.id %>"><%= lang === 'en' ? 'Set primary' : '设为主简历' %></button>
            <button class="btn btn-danger" type="button" data-delete-resume data-id="<%= resume.id %>"><%= lang === 'en' ? 'Delete' : '删除' %></button>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <div class="card empty-state">
        <h2><%= lang === 'en' ? 'No resumes uploaded yet' : '还没有上传任何简历' %></h2>
        <p><%= lang === 'en' ? 'Upload a primary resume to unlock matching and cover-letter generation.' : '上传主简历后即可启用职位匹配与 Cover Letter 生成。' %></p>
      </div>
    <% } %>
  </div>
</section>
