{
  "name": "job-hunter",
  "version": "2.0.0",
  "description": "Job Hunter v2",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "scrape:seek": "python scrapers/run_scraper.py --source seek --keywords \"AI Engineer\" --max_pages 1",
    "scrape:apsjobs": "python scrapers/run_scraper.py --source apsjobs --keywords \"AI\" --max_pages 1",
    "verify:descriptions": "node scripts/verifyScraperDescriptions.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "file:vendor/express-rate-limit",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "file:vendor/openai",
    "pdf-parse": "file:vendor/pdf-parse",
    "playwright": "^1.58.2"
  }
}
