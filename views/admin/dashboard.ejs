<% layout('layout') -%>

<section class="page-section admin-section">
  <div class="section-header admin-header">
    <h1>管理面板</h1>
    <p class="section-subtitle">运行分析、上传职位数据，并查看整体求职匹配统计。</p>
  </div>

  <div class="admin-grid stats-grid">
    <section class="glass-card stat-card">
      <h2 class="section-title">运行状态</h2>
      <% if (!lastRun) { %>
      <p>尚未运行过分析。</p>
      <% } else { %>
      <p>
        最近一次运行 ID：<span class="tag"><%= lastRun.id %></span>
      </p>
      <p>
        状态：
        <% if (lastRun.status === 'running') { %>
        <span class="status-pill status-running">运行中</span>
        <% } else if (lastRun.status === 'completed') { %>
        <span class="status-pill status-success">完成</span>
        <% } else { %>
        <span class="status-pill status-failed">失败</span>
        <% } %>
      </p>
      <% if (lastRun.error) { %>
      <p class="muted">错误信息：<%= lastRun.error %></p>
      <% } %>
      <% } %>

      <button id="run-analysis-btn" class="btn btn-primary run-btn">运行分析</button>
      <p id="run-analysis-status" class="muted small run-status"></p>
    </section>

    <section class="glass-card stat-card">
      <h2 class="section-title">数据统计</h2>
      <ul class="stats-list">
        <li>
          <span>职位总数</span>
          <span class="stat-value"><%= jobCounts.total %></span>
        </li>
        <li>
          <span>已打分职位数</span>
          <span class="stat-value"><%= jobCounts.withScore %></span>
        </li>
        <li>
          <span>匹配记录总数</span>
          <span class="stat-value"><%= fitStats.total %></span>
        </li>
        <li>
          <span>平均匹配度</span>
          <span class="stat-value"><%= fitStats.avg.toFixed(1) %>%</span>
        </li>
      </ul>
      <h3 class="mt">高匹配职位数（按角色）</h3>
      <ul class="stats-list">
        <% if (!fitStats.highFitPerRole.length) { %>
        <li><span class="muted">暂无数据</span></li>
        <% } else { %>
        <% fitStats.highFitPerRole.forEach(function(r){ %>
        <li>
          <span><%= r.role || '未知角色' %></span>
          <span><%= r.count %></span>
        </li>
        <% }) %>
        <% } %>
      </ul>
    </section>

    <section class="glass-card admin-section">
      <h2 class="section-title">上传职位数据</h2>
      <p class="muted">
        接受 JSON 格式，内容为职位对象数组：包含 title, company_name, description, role, url,
        location, salary 等字段。
      </p>
      <form id="upload-form">
        <textarea
          id="upload-json"
          rows="8"
          placeholder='[{"title":"Senior AI Engineer", "company_name":"示例公司", "description":"...", "role":"AI Engineer"}]'
        ></textarea>
        <button type="submit" class="btn btn-secondary">上传职位数据</button>
      </form>
      <p id="upload-status" class="muted small"></p>

      <hr class="section-divider" />

      <h3 class="section-title small">通过文件上传职位 JSON</h3>
      <p class="muted small">
        选择本地 JSON 文件上传，文件内容格式与上方文本框一致（职位数组或包含 jobs 数组的对象）。
      </p>
      <form
        id="upload-file-form"
        class="mt"
        action="/admin/jobs/upload?token=job-hunter-admin-2026"
        method="POST"
        enctype="multipart/form-data"
      >
        <input type="file" name="jobFile" accept="application/json" />
        <button type="submit" class="btn btn-secondary">上传职位 JSON 文件</button>
      </form>
    </section>

    <section class="glass-card stat-card">
      <h2 class="section-title">Scraper 控制</h2>
      <p class="muted">
        触发 APSJobs 抓取任务，将最新职位数据写入数据库。运行在后台执行，不会阻塞管理界面。
      </p>

      <button id="trigger-scraper-btn" class="btn btn-secondary run-btn">触发 APSJobs 抓取</button>
      <p id="scraper-status" class="muted small run-status"></p>

      <h3 class="mt">最近抓取运行</h3>
      <div class="table-wrapper">
        <table class="table small" id="scraper-runs-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>抓取器</th>
              <th>状态</th>
              <th>开始时间</th>
              <th>结束时间</th>
              <th>新增职位</th>
              <th>错误信息</th>
            </tr>
          </thead>
          <tbody>
            <% if (!scraperRuns || !scraperRuns.length) { %>
            <tr>
              <td colspan="7" class="muted">暂无抓取记录。</td>
            </tr>
            <% } else { %>
            <% scraperRuns.forEach(function(run){ %>
            <tr data-run-id="<%= run.id %>">
              <td><%= run.id %></td>
              <td><%= run.scraper_name %></td>
              <td>
                <% if (run.status === 'running' || run.status === 'queued') { %>
                <span class="status-pill status-running"><%= run.status %></span>
                <% } else if (run.status === 'success') { %>
                <span class="status-pill status-success">成功</span>
                <% } else { %>
                <span class="status-pill status-failed">失败</span>
                <% } %>
              </td>
              <td><%= run.started_at || '-' %></td>
              <td><%= run.finished_at || '-' %></td>
              <td><%= typeof run.jobs_added === 'number' ? run.jobs_added : '-' %></td>
              <td class="small"><%= run.error_message || '-' %></td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</section>
