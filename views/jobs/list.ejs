<section class="jobs-layout">
  <aside class="card filters-panel">
    <h2><%= lang === 'en' ? 'Filters' : '筛选条件' %></h2>
    <form class="filters-form" data-filter-form>
      <label class="form-field">
        <span><%= lang === 'en' ? 'Source' : '来源' %></span>
        <select name="source">
          <option value=""><%= lang === 'en' ? 'All sources' : '全部来源' %></option>
          <% (sources || []).forEach(function(source) { %>
            <option value="<%= source.name %>" <%= filters.source === source.name ? 'selected' : '' %>><%= source.label %></option>
          <% }) %>
        </select>
      </label>
      <label class="form-field">
        <span><%= lang === 'en' ? 'Keyword' : '关键词' %></span>
        <input type="text" name="keyword" value="<%= filters.keyword || '' %>" />
      </label>
      <label class="form-field">
        <span><%= lang === 'en' ? 'Min score' : '最低分数' %></span>
        <input type="number" name="minScore" min="0" max="100" value="<%= filters.minScore || '' %>" />
      </label>
      <label class="form-field">
        <span><%= lang === 'en' ? 'Status' : '状态' %></span>
        <select name="status">
          <option value=""><%= lang === 'en' ? 'Any status' : '全部状态' %></option>
          <% ['unread','read','applied','not_interested'].forEach(function(status) { %>
            <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
          <% }) %>
        </select>
      </label>
      <input type="hidden" name="lang" value="<%= lang || 'zh' %>" />
      <button class="btn btn-primary" type="submit"><%= lang === 'en' ? 'Apply filters' : '应用筛选' %></button>
    </form>
  </aside>

  <div class="jobs-content">
    <div class="list-header card">
      <div>
        <p class="eyebrow"><%= lang === 'en' ? 'Job list' : '职位列表' %></p>
        <h1><%= lang === 'en' ? `${pagination.total} jobs found` : `共找到 ${pagination.total} 个职位` %></h1>
      </div>
      <a class="btn btn-secondary" href="/scrape?lang=<%= lang || 'zh' %>"><%= lang === 'en' ? 'Scrape new jobs' : '抓取新职位' %></a>
    </div>

    <% if ((jobs || []).length) { %>
      <div class="job-list">
        <% jobs.forEach(function(job) { %>
          <%- include('../partials/job-card', { job: job, lang: lang }) %>
        <% }) %>
      </div>
      <div class="pagination-row card">
        <a class="btn btn-secondary <%= pagination.page <= 1 ? 'is-disabled' : '' %>" href="/jobs?<%= pagination.prevQuery %>"><%= lang === 'en' ? 'Previous' : '上一页' %></a>
        <span><%= lang === 'en' ? `Page ${pagination.page}` : `第 ${pagination.page} 页` %></span>
        <a class="btn btn-secondary <%= !pagination.hasNext ? 'is-disabled' : '' %>" href="/jobs?<%= pagination.nextQuery %>"><%= lang === 'en' ? 'Next' : '下一页' %></a>
      </div>
    <% } else { %>
      <div class="card empty-state">
        <h2><%= lang === 'en' ? 'No jobs match the current filters' : '当前筛选下没有职位' %></h2>
        <p><%= lang === 'en' ? 'Try broadening your search or scraping new sources.' : '可以放宽筛选条件，或者重新抓取更多来源。' %></p>
      </div>
    <% } %>
  </div>
</section>
